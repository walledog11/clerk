{
  "name": "clerk-dashboard",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "node ../../scripts/with-test-env.mjs vitest run --config vitest.unit.config.ts",
    "test:integration": "node ../../scripts/with-test-env.mjs vitest run --config vitest.integration.config.ts",
    "test:watch": "node ../../scripts/with-test-env.mjs vitest --config vitest.integration.config.ts",
    "test:coverage": "node ../../scripts/with-test-env.mjs vitest run --coverage --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "latest",
    "@clerk/db": "*",
    "@clerk/nextjs": "^7.0.5",
    "@sentry/nextjs": "latest",
    "@upstash/redis": "^1.37.0",
    "class-variance-authority": "^0.7.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^1.7.0",
    "motion": "^12.38.0",
    "next": "latest",
    "openai": "latest",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "postmark": "latest",
    "radix-ui": "^1.4.3",
    "react": "latest",
    "react-dom": "latest",
    "stripe": "^21.0.1",
    "swr": "latest",
    "twilio": "^5.13.1"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.3",
    "vitest": "^4.1.3"
  }
}
